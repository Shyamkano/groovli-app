{
  "expo": {
    "name": "Groovli",
    "slug": "groovli",
    "description": " Groovli: A high-performance, premium music streaming application built with React Native & Expo. Featuring a minimalist Cherry-themed UI and seamless JioSaavn API integration.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.groovli.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.groovli.app",
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/image.png",
          "color": "#FF006B",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "compileSdkVersion": 36,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ],
      "./plugins/withAndroidMediaSession",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "72e2f5dc-ed2a-40e5-91bf-beb0591450ae"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/72e2f5dc-ed2a-40e5-91bf-beb0591450ae"
    }
  }
}
